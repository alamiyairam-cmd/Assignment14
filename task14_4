import numpy as np
arr = np.arange(1, 25)
print("Original 1D Array:")
print(arr)
arr1 = arr.reshape(4, 6)
print("\nReshape (4, 6):")
print(arr1)
print("Shape:", arr1.shape)
arr2 = arr.reshape(3, 8)
print("\nReshape (3, 8):")
print(arr2)
print("Shape:", arr2.shape)
arr3 = arr.reshape(2, 3, 4)
print("\nReshape (2, 3, 4):")
print(arr3)
print("Shape:", arr3.shape)
