import numpy as np
A = np.random.randint(1, 11, (3, 3))
B = np.random.randint(1, 11, (3, 3))
print("Matrix A:")
print(A)
print("\nMatrix B:")
print(B)
print("\nAddition (A + B):")
print(A + B)
print("\nSubtraction (A - B):")
print(A - B)
print("\nMatrix Multiplication (A @ B):")
print(A @ B)
print("\nElement-wise Multiplication (A * B):")
print(A * B)
print("\nTranspose of Matrix A:")
print(A.T)
